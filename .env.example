# SQLite DB ファイルパス (data/ ディレクトリは .gitignore 済み)
# Prisma は schema.prisma (prisma/) からの相対パスで解決するので "../data/..."
DATABASE_URL="file:../data/db.sqlite"

# PWA からの API アクセスに使う Bearer token
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ASSET_TRACKER_TOKEN="replace-me-with-random-hex"

# Fastify が bind する Tailscale IP (`tailscale ip -4` の出力)
# LAN/Internet に bind しないため必須
TAILSCALE_IP="100.0.0.0"

# Fastify ポート
PORT="3000"

# pino ログレベル
LOG_LEVEL="info"

NODE_ENV="development"

# Webull JP OpenAPI credentials
# 取得方法: https://developer.webull.co.jp/ → OpenAPI 利用申請 → 承認後 API Key 生成
# 両方とも未設定なら Webull adapter はスキップされる
WEBULL_APP_KEY=""
WEBULL_APP_SECRET=""

# サブ枠: 401 切り分け用に追加で払い出した App key/secret を保持。
# WEBULL_USE_SUB=1 を付けると client.ts がこちらを使うように切替。
WEBULL_APP_KEY_SUB=""
WEBULL_APP_SECRET_SUB=""
WEBULL_USE_SUB=""

# scrape 結果を別ホスト (常時稼働の Pi 等) に同期したい場合の宛先 base URL。
# 設定すると runAdapter は local persist 完了後に POST {target}/api/sync する。
# 例: PC では SYNC_TARGET="http://100.85.86.51:3000" (Pi の tailnet IP)
# Pi 側は未設定 (Pi 自身は同期元なので空のまま)。
SYNC_TARGET=""
