// Asset Tracker DB schema
// 詳細は .claude/docs/plan.md §6 参照

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =============================================================================
// 静的マスタ (口座・銘柄)
// =============================================================================

// 口座 (銀行口座 or 証券口座)
model Account {
  id            String   @id @default(cuid())
  kind          String   // 'bank' | 'brokerage'
  institution   String   // 'rakuten_bank' | 'mufg' | 'sbi_sumishin' | 'rakuten_sec' | 'sbi_sec' | 'webull' | 'moomoo'
  source        String   // 'moneyforward' | 'direct_scrape' | 'webull_api' | 'moomoo_api' | 'manual'
  label         String
  baseCurrency  String
  credentialRef String?
  tags          String   @default("[]")
  meta          String   @default("{}")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  snapshots    AccountSnapshot[]
  holdings     Holding[]
  transactions Transaction[]
  dividends    Dividend[]

  @@unique([institution, label])
}

// 銘柄マスタ (口座を跨いで共有)
// sector/industry は GICS 等の固定タクソノミー (1 銘柄 1 値、自動取得想定)。
// 多値の投資テーマ (半導体 / AI / 量子 等) は Category + SecurityCategory で扱う。
model Security {
  id         String   @id @default(cuid())
  symbol     String
  exchange   String?
  isin       String?
  name       String
  currency   String
  assetClass String   // 'cash' | 'stock' | 'etf' | 'mutual_fund' | 'reit' | 'bond' | 'crypto' | 'commodity' | 'other'
  region     String?  // 'jp' | 'us' | 'hk' | 'cn' | 'eu' | 'em' | 'global' | 'other'
  sector     String?  // GICS sector level 1 (例 'Information Technology')
  industry   String?  // GICS industry (例 'Semiconductors')
  // レバレッジ倍率。現物=1, ブル=正 (3倍ブル=3), ベア=負 (3倍ベア=-3)
  leverage   Float    @default(1)
  tags       String   @default("[]")
  meta       String   @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  holdings     Holding[]
  prices       PriceSnapshot[]
  transactions Transaction[]
  dividends    Dividend[]
  categories   SecurityCategory[]

  @@unique([symbol, exchange])
}

// =============================================================================
// 投資テーマ (Category) — GICS とは別系統で 1 銘柄が複数テーマに属せる + weight
// 例: NVDA → 半導体, AI, データセンター (3 テーマ、weight でサブ配分)
//     QQQ  → IT 0.5, 通信 0.2, 消費 0.15, ヘルスケア 0.1, その他 0.05
// =============================================================================

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique  // 'semiconductor', 'quantum', 'ai' 等
  kind        String   @default("theme")  // v1='theme'、将来 'watchlist'/'custom'
  name        String   // 表示名 '半導体' '量子' 'AI'
  description String?
  parentId    String?  // ツリー構造 (半導体製造装置 ⊂ 半導体 等)
  color       String?  // UI 色 (省略可、自動割当)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  parent     Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]        @relation("CategoryTree")
  securities SecurityCategory[]
}

model SecurityCategory {
  securityId String
  categoryId String
  weight     Decimal  @default(1.0)  // 構成比 (個別株は通常 1.0、ETF/MF はサブ比率)
  source     String   @default("user")  // 'user' | 'seed' | 'auto'
  notedAt    DateTime @default(now())

  security Security @relation(fields: [securityId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([securityId, categoryId])
  @@index([categoryId])
}

// 口座 × 銘柄 のリンク
model Holding {
  id         String   @id @default(cuid())
  accountId  String
  securityId String
  subAccount String?  // 'nisa_growth' | 'nisa_tsumitate' | 'tokutei' | 'ippan' (v1 では null 可)
  meta       String   @default("{}")
  createdAt  DateTime @default(now())

  account   Account           @relation(fields: [accountId], references: [id])
  security  Security          @relation(fields: [securityId], references: [id])
  snapshots HoldingSnapshot[]

  @@unique([accountId, securityId, subAccount])
}

// =============================================================================
// 時系列スナップショット (1 日 1 行で upsert: 同日再 scrape は上書き、日跨ぎは新行)
// capturedDate は JST 日付 "YYYY-MM-DD" 文字列
// =============================================================================

model AccountSnapshot {
  id               String   @id @default(cuid())
  accountId        String
  capturedAt       DateTime
  capturedDate     String   // JST "YYYY-MM-DD" — 日単位の bucket、upsert キー
  totalValueNative Decimal
  totalValueJpy    Decimal
  cashNative       Decimal
  cashJpy          Decimal
  fxRate           Decimal?
  rawJson          String?

  account          Account           @relation(fields: [accountId], references: [id])
  holdingSnapshots HoldingSnapshot[]

  @@unique([accountId, capturedDate])
  @@index([accountId, capturedAt])
}

model HoldingSnapshot {
  id                  String   @id @default(cuid())
  snapshotId          String
  holdingId           String
  capturedDate        String   // JST "YYYY-MM-DD" — Holding 単位でも upsert キー
  quantity            Decimal
  marketPriceNative   Decimal
  marketPriceJpy      Decimal
  marketValueNative   Decimal
  marketValueJpy      Decimal
  avgCostNative       Decimal?
  unrealizedPnlNative Decimal?
  unrealizedPnlJpy    Decimal?

  accountSnapshot AccountSnapshot @relation(fields: [snapshotId], references: [id])
  holding         Holding         @relation(fields: [holdingId], references: [id])

  @@unique([holdingId, capturedDate])
  @@index([holdingId, capturedDate])
}

model PriceSnapshot {
  id           String   @id @default(cuid())
  securityId   String
  capturedAt   DateTime
  capturedDate String
  priceNative  Decimal
  priceJpy     Decimal

  security Security @relation(fields: [securityId], references: [id])

  @@unique([securityId, capturedDate])
  @@index([securityId, capturedAt])
}

model FxRate {
  id           String   @id @default(cuid())
  base         String
  quote        String
  capturedAt   DateTime
  capturedDate String
  rate         Decimal

  @@unique([base, quote, capturedDate])
  @@index([base, quote, capturedAt])
}

// =============================================================================
// イベント (取引・配当) — v1.5 で MF 取引履歴ページから埋める。
// externalId (MF / 証券会社の取引 ID) で重複防止 → 何度 scrape しても同じイベントは 1 行
// =============================================================================

model Transaction {
  id           String   @id @default(cuid())
  accountId    String
  securityId   String?  // 入出金・利息など cash イベントは null
  type         String   // 'deposit'/'withdraw'/'buy'/'sell'/'transfer_in'/'transfer_out'/'fee'/'tax'/'interest'
  occurredAt   DateTime // 約定日
  settledAt    DateTime? // 受渡日 (証券は T+2 等)
  quantity     Decimal? // buy/sell の数量
  priceNative  Decimal? // 単価
  amountNative Decimal  // 受払金額 (この口座通貨、cash 増減)
  feeNative    Decimal? // 手数料
  taxNative    Decimal? // 源泉徴収
  amountJpy    Decimal  // JPY 換算受払金額
  fxRate       Decimal?
  currency     String
  subAccount   String?  // 'nisa_growth' | 'nisa_tsumitate' | 'tokutei' | 'ippan'
  externalId   String?  // MF / 証券会社の取引 ID
  note         String?
  rawJson      String?

  account  Account   @relation(fields: [accountId], references: [id])
  security Security? @relation(fields: [securityId], references: [id])

  @@unique([accountId, externalId])
  @@index([accountId, occurredAt])
  @@index([securityId, occurredAt])
}

model Dividend {
  id               String   @id @default(cuid())
  accountId        String
  securityId       String
  exDate           DateTime? // 権利落ち日
  recordDate       DateTime? // 権利確定日
  paidAt           DateTime  // 支払日
  quantity         Decimal   // 受領時の保有数
  dividendPerShare Decimal
  grossNative      Decimal   // 税引前
  taxNative        Decimal   // 源泉
  netNative        Decimal   // 手取り
  netJpy           Decimal
  fxRate           Decimal?
  currency         String
  subAccount       String?
  externalId       String?
  rawJson          String?

  account  Account  @relation(fields: [accountId], references: [id])
  security Security @relation(fields: [securityId], references: [id])

  @@unique([accountId, externalId])
  @@index([securityId, paidAt])
}

// =============================================================================
// 運用ログ
// =============================================================================

model ScrapeRun {
  id              String    @id @default(cuid())
  source          String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String    // 'ok' | 'error' | 'running' | 'needs_2fa'
  errorMsg        String?
  accountsTouched Int       @default(0)
}
